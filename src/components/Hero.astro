<script>
  import { gsap } from 'gsap';

  const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

  tl.to('#hero-name',  { opacity: 1, y: 0, duration: 0.9 }, 0.15)
    .to('#hero-hand',  { opacity: 1, duration: 0.6 }, 0.8)
    .to('#hero-sub',   { opacity: 1, y: 0, duration: 0.7 }, 0.95)
    .to('#hero-meta',  { opacity: 1, y: 0, duration: 0.7 }, 1.3);
</script>
