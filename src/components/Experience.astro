---
const jobs = [
  {
    no: '01',
    company: 'Amazon Robotics',
    role: 'Data Operations Technician',
    period: '01/2026 — Present',
    location: 'San Francisco, CA',
    bullets: [
      'Serve as point of contact for shift-level execution, coordinating with the team to resolve collection errors and maintain workflow continuity through extended runs.',
      'Monitor collection health metrics and drive process improvements to increase dataset consistency and operational efficiency.',
      'Manage, train and onboard team on data-collection protocols and quality standards, driving and maintaining measurable improvements in team with a 91% data yield.',
    ],
  },
  {
    no: '02',
    company: 'Google DeepMind',
    role: 'Mechatronics Data Analyst Intern',
    period: '11/2025 — 01/2026',
    location: 'Mountain View, CA',
    bullets: [
      'Coordinated mechatronic operations and analyzed performance data to identify error patterns, improving operational efficiency by 12% and reducing task retries.',
      'Built real-time monitoring for teleoperation workflows and analyzed operator performance metrics to identify areas for improvement, leading to targeted training sessions.',
    ],
  },
  {
    no: '03',
    company: 'Skild AI',
    role: 'Operations Coordinator',
    period: '06/2025 — 11/2025',
    location: 'San Mateo, CA',
    bullets: [
      'Coordinated multi-operator schedules and standardized labeling protocols, improving dataset and operator retention.',
      'Authored SOPs and process documentation, ran QA checks to maintain quality and repeatability across data-collection workflows.',
      'Tracked KPIs (throughput, latency, cycle time) and coordinated changes with engineering to keep runs on schedule.',
      'Ran enterprise demos for NVIDIA, Samsung, LG, managing run-of-show, reliability gates and fallback plans.',
    ],
  },
];
---

<section id="experience" class="chapter">
  <header class="chapter__head">
    <span class="chapter__num">02</span>
    <h2 class="chapter__title">Work<br /><em>Experience</em></h2>
    <p class="chapter__lede">Three AI-first companies in eighteen months.</p>
  </header>

  <div class="reveal">
    {jobs.map(job => (
      <div class="exp-entry">
        <div class="exp-entry__meta">
          <span class="row__no" style="font-size: var(--t-md);">{job.no}</span>
          <div>
            <div class="exp-entry__co">
              {job.company}
            </div>
            <span class="exp-entry__role">{job.role}</span>
          </div>
          <span class="exp-entry__date">{job.period} · {job.location}</span>
        </div>
        <ul class="exp-entry__bullets">
          {job.bullets.map(b => <li>{b}</li>)}
        </ul>
      </div>
    ))}
  </div>

  <!-- Education -->
  <div class="edu-block reveal">
    <div>
      <span class="chapter__num" style="font-size: var(--t-sm);">04</span>
    </div>
    <div>
      <div class="exp-entry__co">
        San Jose State University
        <em style="font-size: 0.7em; margin-left: 8px;">B.S. MIS</em>
      </div>
      <span class="exp-entry__role">Management Information Systems</span>
      <p style="margin: var(--s-2) 0 0; font-size: var(--t-sm); color: var(--ink-mute); font-family: var(--f-mono);">
        12/2025 · San Jose, CA
      </p>
      <p style="margin: var(--s-3) 0 0; color: var(--ink-soft); font-size: var(--t-sm); max-width: 60ch;">
        IT Project Management · Systems Analysis &amp; Design · Strategic Management · Python &amp; Java
      </p>
    </div>
  </div>
</section>
