---
const groups = [
  {
    name: 'Program & Project Mgmt',
    skills: ['Cross-Functional Coordination', 'Agile / Scrum', 'SOP Development', 'Process Documentation', 'KPI Tracking', 'Risk Escalation', 'Stakeholder Communication'],
  },
  {
    name: 'Operations & Data',
    skills: ['Robotics & ML Data Operations', 'QA & Quality Standards', 'Team Onboarding & Training', 'Scheduling', 'Data Analysis', 'Annotation & Labeling', 'Tableau / Power BI'],
  },
  {
    name: 'Tools',
    skills: ['Microsoft Excel & 365', 'Quip / PIDP / Sagemaker', 'JIRA', 'Asana', 'ETL Tools', 'Python', 'Bash', 'SQL'],
  },
  {
    name: 'Languages',
    skills: ['English', 'Hindi', 'Kannada', 'Tamil', 'Telugu', 'Spanish'],
    ghost: true,
  },
];
---

<section id="skills" class="chapter">
  <header class="chapter__head">
    <span class="chapter__num">03</span>
    <h2 class="chapter__title">Skills &<br /><em>Toolset</em></h2>
    <p class="chapter__lede">What I bring to the table — from robots to spreadsheets.</p>
  </header>

  <div class="reveal">
    {groups.map(group => (
      <div class="skills-group">
        <span class="skills-group__name">{group.name}</span>
        <div class="skills-group__tags reveal-stagger">
          {group.skills.map(skill => (
            <span class={`tag${group.ghost ? ' tag--ghost' : ''}`}>{skill}</span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Certifications row -->
  <div style="border-top: 1.5px solid var(--ink); padding-top: var(--s-5); margin-top: var(--s-6);" class="reveal">
    <span class="kicker" style="display:block; margin-bottom: var(--s-4);">Certifications</span>
    <div class="reveal-stagger" style="display: flex; flex-wrap: wrap; gap: var(--s-3);">
      {[
        'Google Data Analytics Certificate',
        'AWS Certified Cloud Practitioner',
        'Microsoft Azure Data Fundamentals (DP-900)',
        'Professional Scrum Master I',
        'Amazon AI/ML Scholar',
      ].map(cert => (
        <span class="tag tag--active">{cert}</span>
      ))}
    </div>
  </div>
</section>
